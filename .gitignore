# --- Secrets / credentials (never commit these) ---
.env
.env.*
!.env.example
*.key
*.pem
secrets.json
credentials.json

# --- OS cruft ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp

# --- Logs ---
*.log
logs/

# --- Node (if used) ---
node_modules/
dist/
build/
.npm/

# --- Python (if used) ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# --- MQL5 / MetaTrader build artifacts ---
# Ignore OUR compiled output, but keep third-party indicator .ex5 deps tracked
# (e.g. MQL5/Indicators/SchaffTrendCycle.ex5, which has no source).
/MQL5/Experts/*.ex5
/MQL5/Scripts/*.ex5
*.ex4
*.log
